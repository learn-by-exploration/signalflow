# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/signalflow
DATABASE_URL_SYNC=postgresql://postgres:YOUR_PASSWORD@localhost:5432/signalflow
REDIS_URL=redis://localhost:6379/0
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD_HERE
POSTGRES_USER=postgres
POSTGRES_DB=signalflow
# REDIS_PASSWORD=            # Set for production (used by docker-compose.prod.yml)

# ── AI Engine ──
ANTHROPIC_API_KEY=sk-ant-...
MONTHLY_AI_BUDGET_USD=30

# ── Market Data ──
ALPHA_VANTAGE_API_KEY=
BINANCE_API_KEY=
BINANCE_SECRET=
COINMARKETCAP_API_KEY=

# ── Alerts ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# ── Monitoring ──
SENTRY_DSN=

# ── App Config ──
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# ── API Auth ──
API_SECRET_KEY=                # Generate with: openssl rand -base64 32 (shared secret for frontend → backend)

# ── Auth (Frontend) ──
NEXTAUTH_SECRET=               # Generate with: openssl rand -base64 32
ADMIN_EMAIL=admin@signalflow.ai
ADMIN_PASSWORD=                # Set a strong password
DEMO_EMAIL=demo@signalflow.ai
DEMO_PASSWORD=                 # Set a password for the demo account

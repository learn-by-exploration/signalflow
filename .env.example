# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/signalflow
DATABASE_URL_SYNC=postgresql://postgres:YOUR_PASSWORD@localhost:5432/signalflow
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=                # Set for production (used by docker-compose)
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD_HERE
POSTGRES_USER=postgres
POSTGRES_DB=signalflow

# ── AI Engine ──
ANTHROPIC_API_KEY=sk-ant-...
MONTHLY_AI_BUDGET_USD=30
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Market Data ──
ALPHA_VANTAGE_API_KEY=
BINANCE_API_KEY=
BINANCE_SECRET=
COINMARKETCAP_API_KEY=

# ── Alerts ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# ── Monitoring ──
SENTRY_DSN=

# ── App Config ──
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# ── Security ──
API_SECRET_KEY=                # Generate with: openssl rand -base64 32 (shared secret for frontend → backend)
JWT_SECRET_KEY=                # Generate with: openssl rand -base64 32 (HMAC signing key for JWT tokens)
INTERNAL_API_KEY=              # Generate with: openssl rand -base64 32 (for Celery/bot internal calls)
ALLOWED_HOSTS=                 # Comma-separated hostnames for production (e.g., signalflow.example.com)
MAX_REQUEST_BODY_BYTES=1048576 # 1MB max request body size

# ── Auth (Frontend) ──
NEXTAUTH_SECRET=               # Generate with: openssl rand -base64 32

# ── Payments (Razorpay) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_MONTHLY_PLAN_ID=     # Razorpay Plan ID for ₹499/mo subscription
RAZORPAY_ANNUAL_PLAN_ID=      # Razorpay Plan ID for ₹4999/yr subscription
PRO_TRIAL_DAYS=7              # Free Pro trial duration
PAYMENT_GRACE_DAYS=3          # Grace period before downgrade on failed payment

# ── Monitoring (Flower) ──
FLOWER_USER=admin
FLOWER_PASSWORD=               # Celery Flower dashboard password
